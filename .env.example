# Educaty — app mobile companheiro (Expo). Copie para .env e preencha.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_REVENUECAT_API_KEY=

# ── Segredos das Edge Functions (NÃO vão no app; set via `supabase secrets set`) ──
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY  (injetados pelo runtime)
# REVENUECAT_SECRET_KEY, REVENUECAT_WEBHOOK_SECRET
# RESEND_API_KEY, NOTIFY_SECRET
# ADMIN_DELETE_SECRET   (o MESMO valor precisa estar no painel N3 como EDUCATY_ADMIN_DELETE_SECRET)
